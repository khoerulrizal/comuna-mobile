{
  "expo": {
    "name": "Comuna",
    "slug": "comuna-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "comuna",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "id.comuna.app",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "id.comuna.app",
      "adaptiveIcon": {
        "backgroundColor": "#6B5BFF",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 150,
          "backgroundColor": "#6B5BFF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 150,
            "backgroundColor": "#6B5BFF"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Comuna menggunakan Face ID untuk membuka aplikasi dengan aman."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Comuna memerlukan kamera untuk swafoto saat absen kehadiran.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Comuna memerlukan lokasi untuk memvalidasi kehadiran di area kantor."
        }
      ],
      [
        "expo-maps",
        {
          "requestLocationPermission": true,
          "locationPermission": "Comuna menampilkan posisi Anda di peta untuk validasi kehadiran."
        }
      ],
      [
        "react-native-fast-tflite",
        {
          "enableCoreMLDelegate": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Comuna memerlukan akses galeri untuk melampirkan dokumen pengajuan cuti.",
          "cameraPermission": "Comuna memerlukan kamera untuk memfoto lampiran pengajuan cuti."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#6B5BFF"
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
